{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Estudo sobre o site https://www.tabnews.com.br desenvolvido durante o curso \"https://curso.dev/\"",
  "main": "index.js",
  "scripts": {
    "dev": "npm run docker:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "test": "npm run docker:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\" ",
    "test:watch": "jest --watchAll --runInBand",
    "docker:build": "docker compose -f infra/compose.yaml build",
    "docker:up": "docker compose -f infra/compose.yaml up -d",
    "docker:stop": "docker compose -f infra/compose.yaml stop",
    "docker:down": "docker compose -f infra/compose.yaml down",
    "docker:logs": "docker compose -f infra/compose.yaml logs -f",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migration:down": "node-pg-migrate -m infra/migrations --envPath .env.development down",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@next/env": "^16.1.6",
    "async-retry": "^1.3.3",
    "dotenv": "^16.4.4",
    "dotenv-expand": "^11.0.6",
    "next": "^13.1.6",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^28.6.0",
    "jest": "^29.6.2",
    "prettier": "^3.6.2"
  }
}
